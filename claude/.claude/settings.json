{
  "permissions": {
    "allow": [
      "Bash(pwd)",
      "Bash(whoami)",
      "Bash(id)",
      "Bash(hostname)",
      "Bash(date)",
      "Bash(uptime)",
      "Bash(uname -a)",
      "Bash(env)",
      "Bash(ls)",
      "Bash(ls -la)",
      "Bash(ls -l)",
      "Bash(tree)",
      "Bash(df -h)",
      "Bash(git status)",
      "Bash(git branch)",
      "Bash(git branch -v)",
      "Bash(git remote -v)",
      "Bash(git stash list)",
      "Bash(git log --oneline)",
      "Bash(git log --oneline -20)",
      "Bash(git diff)",
      "Bash(git diff --staged)",
      "Bash(git remote get-url origin)",
      "Bash(git rev-parse HEAD)",
      "Bash(git show --stat)",
      "Bash(find)",
      "Bash(which)",
      "Bash(command -v)",
      "Bash(cat)"
    ],
    "deny": []
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -f .claude/NOTES.md ] && { echo '## Repo notes'; cat .claude/NOTES.md; }; true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p ~/.claude/logs && jq -r '\"\\(now | todate) \\(.tool_input.command)\"' >> ~/.claude/logs/bash-$(date +%Y-%m).log"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  }
}
